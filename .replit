modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 19591
externalPort = 3002

[[ports]]
localPort = 20295
externalPort = 3000

[userenv]

[userenv.shared]
SNAPSHOT_SECRET = "sc_6d53f8f17946d466cb20a5f8a0d815aa4dfbcd6aaa6c295759240463733053a8"

[nix]
channel = "stable-25_05"
