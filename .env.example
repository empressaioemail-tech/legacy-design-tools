# Example env for cortex-api / api-server (copy relevant vars to .env.local).
# See docs/deploy.md for production Secret Manager bindings.

# --- Property Brief / investor radar ---
# BROKERAGE_EXTENSION_PUBLIC_KEY=   # Chrome Web Store public key (required for /brief)
# BROKERAGE_API_KEYS=               # optional operator/MCP keys (comma-separated)
# BROKERAGE_FEDERAL_DATA_DIR=       # live OZ + SPDPID registry (image default: /app/var/brokerage-federal-data)
# OZ_TRACT_DATA_PATH=
# TX_SPECIAL_DISTRICTS_DATA_PATH=
