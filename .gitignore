# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# Playwright
test-results/
playwright-report/
playwright/.cache/

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Cursor — local agent runtime (session state; not project source)
.claude/

# Local one-off test/CI triage captures (e.g. Vitest extracts under artifacts/plan-review)
.sc-triage/

# One-off git bundle at repo root (keep backups outside the repo)
/replit-103-commits.bundle

# Conversation transcripts auto-saved by the workspace shouldn't ride along
# with code changes — they're per-session ephemera, not project artifacts.
attached_assets/Pasted-*.txt
