# Directory mounted at /db. On GCE, point this at the mounted persistent disk.
OVERPASS_DB_DIR=./data

# Defaults to localhost. On GCE, set 0.0.0.0 only after firewalling this port
# to the Cloud Run VPC connector range (never 0.0.0.0/0).
OVERPASS_BIND_ADDRESS=127.0.0.1
OVERPASS_PORT=8080

# Texas Geofabrik extract. Override only to intentionally change the extract.
OVERPASS_PLANET_URL=https://download.geofabrik.de/north-america/us/texas-latest.osm.pbf

# Query and process limits for the private service.
OVERPASS_FASTCGI_PROCESSES=4
OVERPASS_RATE_LIMIT=16
OVERPASS_TIME=120
OVERPASS_MAX_TIMEOUT=180
