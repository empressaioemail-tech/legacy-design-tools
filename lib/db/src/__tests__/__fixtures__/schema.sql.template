-- Name: findings; Type: TABLE; Schema: public; Owner: -

CREATE TABLE @@SCHEMA@@.findings (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    atom_id text NOT NULL,
    submission_id uuid NOT NULL,
    severity text NOT NULL,
    category text NOT NULL,
    status text DEFAULT 'ai-produced'::text NOT NULL,
    text text NOT NULL,
    citations jsonb DEFAULT '[]'::jsonb NOT NULL,
    confidence numeric NOT NULL,
    low_confidence boolean DEFAULT false NOT NULL,
    reviewer_status_by jsonb,
    reviewer_status_changed_at timestamp with time zone,
    reviewer_comment text,
    element_ref text,
    source_ref jsonb,
    ai_generated_at timestamp with time zone DEFAULT now() NOT NULL,
    revision_of uuid,
    finding_run_id uuid,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT findings_category_check CHECK ((category = ANY (ARRAY['setback'::text, 'height'::text, 'coverage'::text, 'egress'::text, 'use'::text, 'overlay-conflict'::text, 'divergence-related'::text, 'other'::text]))),
    CONSTRAINT findings_severity_check CHECK ((severity = ANY (ARRAY['blocker'::text, 'concern'::text, 'advisory'::text]))),
    CONSTRAINT findings_status_check CHECK ((status = ANY (ARRAY['ai-produced'::text, 'accepted'::text, 'rejected'::text, 'overridden'::text, 'promoted-to-architect'::text])))
);


