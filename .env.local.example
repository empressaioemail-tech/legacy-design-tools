# Copy to .env.local (gitignored):
#   copy .env.local.example .env.local
#
# Full runbook: docs/local-dev-windows.md
# Daily start:     .\scripts\dev-local-windows.ps1
# Smoke test:      .\scripts\verify-local-pipeline.ps1

# --- Required (local api-server dev:local) ---

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# BIM GLB + sheets + render mirrors (GCS). Without these, /api/.../glb returns HTTP 500.
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\cente\google-cloud-sdk\smartcity-agent-key.json
PUBLIC_OBJECT_SEARCH_PATHS=/legacy-design-tools-prod-objects/public
PRIVATE_OBJECT_DIR=/legacy-design-tools-prod-objects/.private

# --- Optional: real Studio / mnml stills (default is mock) ---
# MNML_RENDER_MODE=http
# MNML_API_URL=https://api.mnmlai.dev
# MNML_API_KEY=
# Smoke: .\scripts\verify-local-pipeline.ps1 -EngagementId <uuid> -TestRenderKickoff

# Optional — api-server dev boot (defaults applied by dev-local-windows.ps1 if unset)
# SNAPSHOT_SECRET=dev-local-snapshot-secret
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=http://127.0.0.1:9
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=dev-key-not-real

# Live Hauska substrate catalog (Code Library — QA-61). Default is mock (5 fixture rows).
# HAUSKA_SUBSTRATE_MODE=mcp
# HAUSKA_MCP_URL=https://<your-hauska-mcp-host>/mcp
# HAUSKA_MCP_KEY=<cortex product key from hauska-mcp-server admin>
# Verify after restart: curl http://localhost:8080/api/substrate/health
# curl http://localhost:8080/api/substrate/jurisdictions?states=TX

# Optional — real Canva OAuth (see artifacts/api-server/README-canva.md)
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
# CANVA_REDIRECT_URI=http://localhost:8080/api/canva/oauth/callback
# CANVA_OAUTH_SUCCESS_URL=http://localhost:20295/

# Optional — Property Brief / investor radar (brokerage API)
# BROKERAGE_EXTENSION_PUBLIC_KEY=   # required for extension /brief (Chrome Web Store)
# BROKERAGE_API_KEYS=               # optional comma-separated operator/MCP keys
# BROKERAGE_FEDERAL_DATA_DIR=       # live OZ + SPDPID data (Docker: /app/var/brokerage-federal-data)
# OZ_TRACT_DATA_PATH=               # override OZ GeoJSON file path
# TX_SPECIAL_DISTRICTS_DATA_PATH=   # override TX special-district registry JSON
# PLACID_API_TOKEN=
# PLACID_TEST_MODE=true
# PLACID_TEMPLATE_COVER=
# PLACID_TEMPLATE_PLAN=
# PLACID_TEMPLATE_CLOSING=
# COLLATERAL_SIGNING_SECRET=
# VITE_COLLATERAL_API=1
# VITE_CANVA_AUTOFILL=0
